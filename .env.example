# ===================================================================
# NOVAMART E-COMMERCE BACKEND - ENVIRONMENT CONFIGURATION
# ===================================================================
# Copy this file to .env and fill in your actual values

# ===================================================================
# ASGARDEO OAUTH2 CONFIGURATION
# ===================================================================
# Replace with your actual Asgardeo organization name
ASGARDEO_ORG_NAME=your-organization-name

# Your Asgardeo application credentials
ASGARDEO_CLIENT_ID=your-client-id-here
ASGARDEO_CLIENT_SECRET=your-client-secret-here

# ===================================================================
# DATABASE CONFIGURATION
# ===================================================================
# MongoDB connection string (replace with your actual MongoDB URI)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# ===================================================================
# JWT CONFIGURATION (for local authentication)
# ===================================================================
# Use a strong secret key for JWT signing (minimum 32 characters)
JWT_SECRET=your-super-secure-jwt-secret-key-here-minimum-32-chars

# JWT expiration time in milliseconds (default: 24 hours)
JWT_EXPIRATION=86400000

# ===================================================================
# CORS CONFIGURATION
# ===================================================================
# Allowed origins for CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000,https://your-frontend-domain.com

# ===================================================================
# RATE LIMITING CONFIGURATION
# ===================================================================
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL=10
RATE_LIMIT_DURATION=1

# ===================================================================
# LOGGING CONFIGURATION
# ===================================================================
# Log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# ===================================================================
# SERVER CONFIGURATION
# ===================================================================
SERVER_PORT=8080
